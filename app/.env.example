# Smart WMS Agent — 환경변수 예시
# 이 파일을 복사해 app/.env 로 만들고 회사 제공 OpenAI 키를 넣으세요.
#   Windows:  copy .env.example .env
# .env 는 git 에 올라가지 않습니다(.gitignore).
# 키는 Phase 5(RAG, 임베딩)부터 실제로 필요합니다. Phase 1~4 는 키 없이 동작.

OPENAI_API_KEY=atl-...
# 회사 게이트웨이 (Azure OpenAI 호환) — AzureOpenAI 클라이언트 사용
OPENAI_BASE_URL=https://skax.ai-talentlab.com
OPENAI_API_VERSION=2024-12-01-preview

# 모델 = Azure deployment 이름. OpenAI 단일 공급자 (생성 + 임베딩)
OPENAI_CHAT_MODEL=gpt-5            # 응답 생성·추론·Tool 사용 (메인)
OPENAI_ROUTER_MODEL=gpt-5-mini    # 라우터·파라미터 추출 (경량·빠름)
OPENAI_EMBED_MODEL=text-embedding-3-small
